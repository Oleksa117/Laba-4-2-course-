<Window x:Class="Lab4.Forms.DeviceForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Створення пристрою"
        Height="250"
        Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Місце кріплення:"
                   Margin="5"/>

        <TextBox x:Name="PositionTextBox"
                 Grid.Column="1"
                 Margin="5"/>

        <TextBlock Grid.Row="1"
                   Text="Дата калібрування:"
                   Margin="5"/>

        <DatePicker x:Name="CalibrationDatePicker"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"/>

        <Button x:Name="SensorButton"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="5"
                Content="Створити датчик"
                Click="SensorButton_Click"/>

        <Button Grid.Row="3"
                Grid.ColumnSpan="2"
                Width="120"
                Height="30"
                Margin="5"
                HorizontalAlignment="Center"
                Content="Створити"
                Click="CreateButton_Click"/>

    </Grid>
</Window>